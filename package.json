{
  "name": "mcp-forge",
  "version": "0.1.0",
  "description": "Opinionated CLI to scaffold, test, and publish MCP servers. From zero to published server in under 5 minutes.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-forge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "node --test dist/index.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "scaffold",
    "cli",
    "anthropic",
    "claude",
    "sovereign-shovels"
  ],
  "author": "Sovereign Shovels <github.com/sovereign-shovels>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sovereign-shovels/mcp-forge.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}
